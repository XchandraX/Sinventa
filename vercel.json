{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "buildCommand": "npm install && npm run build && composer install --no-dev --optimize-autoloader",
    "installCommand": "composer install --no-dev --optimize-autoloader",
    "outputDirectory": "public"
}